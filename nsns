<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>國家安全日 佛梁定向挑戰賽</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://unpkg.com/html5-qrcode"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+HK:wght@400;500;700;900&family=Space+Mono:wght@400;700&display=swap');

        body {
            font-family: 'Noto Sans HK', sans-serif;
            background-color: #020617;
            color: #f8fafc;
            background-image: radial-gradient(circle at center, rgba(14, 165, 233, 0.1) 0%, transparent 70%);
            -webkit-touch-callout: none;
            user-select: none;
        }

        .font-mono { font-family: 'Space Mono', monospace; }
        
        .view-section { display: none; animation: fadeIn 0.4s ease-in-out; }
        .view-section.active { display: flex; flex-direction: column; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* 護照格子 (固定10格) */
        .badge-slot {
            aspect-ratio: 1;
            border-radius: 0.75rem;
            border: 2px dashed #334155;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            background: rgba(15, 23, 42, 0.6);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
        }
        
        .badge-slot.unlocked {
            border: 2px solid #0ea5e9;
            background: #ffffff;
            box-shadow: 0 0 15px rgba(14, 165, 233, 0.4);
            transform: scale(1.05);
        }
        
        .badge-slot .slot-num { font-size: 2rem; font-weight: 900; color: #1e293b; opacity: 0.5; }
        .badge-label { font-size: 0.75rem; font-weight: bold; color: #94a3b8; text-align: center; z-index: 10; margin-top: 5px; }
        
        .badge-slot.unlocked .badge-label { 
            background: rgba(2, 6, 23, 0.85);
            color: #38bdf8;
            padding: 3px 6px;
            border-radius: 4px;
            margin-top: auto;
            margin-bottom: 6px;
            width: 90%;
            font-size: 0.7rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* 模態框 */
        .modal-overlay {
            position: fixed; inset: 0; background: rgba(0, 0, 0, 0.85); backdrop-filter: blur(5px);
            display: none; justify-content: center; align-items: center; z-index: 50;
        }
        .modal-overlay.active { display: flex; animation: fadeIn 0.3s; }
        
        #reader { width: 100%; max-width: 500px; border-radius: 1rem; overflow: hidden; border: 2px solid #0ea5e9; }
        #reader video { object-fit: cover; }
    </style>
</head>
<body class="min-h-screen w-full overflow-x-hidden">

    <!-- ==================== 視圖 1：登入 ==================== -->
    <div id="view-login" class="view-section active min-h-screen justify-center items-center p-6">
        <div class="max-w-md w-full bg-slate-900/80 border border-slate-700 rounded-3xl p-8 text-center shadow-2xl backdrop-blur-md">
            <i class="fa-solid fa-shield-halved text-6xl text-sky-500 mb-6 drop-shadow-[0_0_15px_rgba(14,165,233,0.5)]"></i>
            <h1 class="text-3xl font-black tracking-widest text-white mb-2">國家安全日</h1>
            <p class="text-sky-300 font-bold font-mono text-lg mb-8">佛梁定向挑戰賽</p>
            
            <div class="text-left mb-6">
                <label class="block text-sky-400 text-sm font-bold mb-2 ml-1">特工姓名 / 隊伍班別 (例如: 3A 陳小明) <span class="text-red-500">*</span></label>
                <input type="text" id="team-input" class="w-full bg-slate-950 border border-slate-600 rounded-xl py-4 px-5 text-white font-mono text-lg focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 uppercase transition" placeholder="輸入姓名或隊號...">
            </div>

            <button onclick="startMission()" class="w-full bg-sky-500 hover:bg-sky-400 text-slate-950 font-black text-lg py-4 rounded-xl shadow-[0_0_20px_rgba(14,165,233,0.4)] transition transform hover:scale-105">
                <i class="fa-solid fa-power-off mr-2"></i> 啟動任務 (開始計時)
            </button>
            
            <div class="mt-8 bg-slate-800/60 p-5 rounded-xl border border-slate-700 shadow-inner text-left">
                <h3 class="text-sky-400 font-bold text-lg mb-2"><i class="fa-solid fa-circle-info"></i> 任務說明</h3>
                <p class="text-base text-slate-300 leading-relaxed">系統將為你隨機指派路線並發問，集齊 10 個 QR 徽章後，<span class="text-rose-400 font-bold text-lg underline decoration-rose-500/50 underline-offset-4">需輸入終極密碼方可停止計時！</span></p>
            </div>
        </div>
    </div>

    <!-- ==================== 視圖 2：主控台 ==================== -->
    <div id="view-dashboard" class="view-section min-h-screen pb-28">
        <header class="bg-slate-900 border-b border-slate-700 p-4 sticky top-0 z-30 shadow-md flex justify-between items-center backdrop-blur-md">
            <div>
                <div class="text-xs text-slate-400 font-mono">特工檔案</div>
                <div id="display-team" class="font-bold text-lg text-sky-400">---</div>
            </div>
            <div class="text-right">
                <div class="text-xs text-slate-400 font-mono">任務用時</div>
                <div id="display-timer" class="font-mono font-bold text-2xl text-white tracking-wider">00:00:00</div>
            </div>
        </header>

        <!-- 總部指令面板 (動態目標指派) -->
        <div class="p-4 pb-0">
            <div id="target-directive" class="bg-slate-800 border border-sky-500/50 rounded-2xl p-4 flex items-center justify-between shadow-[0_4px_20px_rgba(14,165,233,0.2)] relative overflow-hidden transition-all">
                <div class="absolute -right-4 -top-4 opacity-10">
                    <i class="fa-solid fa-location-crosshairs text-9xl text-sky-500"></i>
                </div>
                <div class="z-10">
                    <span class="text-sky-400 text-xs font-bold tracking-wider uppercase"><i class="fa-solid fa-radar fa-beat-fade"></i> 總部指令：請前往</span>
                    <div id="next-location-name" class="text-2xl font-black text-white mt-1 drop-shadow-md">計算中...</div>
                </div>
                <div class="z-10 bg-gradient-to-br from-sky-400 to-sky-600 text-slate-900 w-14 h-14 rounded-full flex items-center justify-center text-2xl shadow-lg border-2 border-slate-800">
                    <i class="fa-solid fa-person-running"></i>
                </div>
            </div>
        </div>

        <div class="p-4">
            <div class="flex justify-between items-end mb-2 mt-2">
                <h2 class="font-bold text-lg">護照進度 (集齊 10 個)</h2>
                <span id="progress-text" class="font-mono text-sky-400 font-bold"><span id="badge-count">0</span> / 10</span>
            </div>
            <div class="w-full bg-slate-800 rounded-full h-3 border border-slate-700 overflow-hidden">
                <div id="progress-bar" class="bg-gradient-to-r from-sky-600 to-sky-400 h-3 rounded-full transition-all duration-500" style="width: 0%"></div>
            </div>
        </div>

        <!-- 護照格子 (固定顯示 10 格) -->
        <div class="grid grid-cols-5 gap-2 p-4 pt-0" id="badges-grid">
            <!-- 由 JS 動態生成 10 個格子 -->
        </div>

        <!-- 一般站點掃描按鈕 (集齊 10 個前顯示) -->
        <div id="action-scan" class="fixed bottom-6 left-0 right-0 px-6 flex justify-center z-20">
            <button onclick="openScanner()" class="bg-sky-500 hover:bg-sky-400 text-slate-900 rounded-full py-4 px-8 font-black text-xl shadow-[0_10px_30px_rgba(14,165,233,0.5)] border-2 border-sky-300 flex items-center gap-3 transition transform hover:scale-105">
                <i class="fa-solid fa-qrcode"></i> 掃描站點 QR Code
            </button>
        </div>

        <!-- 終極密碼輸入按鈕 (集齊 10 個後顯示) -->
        <div id="action-final" class="fixed bottom-6 left-0 right-0 px-6 flex justify-center z-20 hidden">
            <button onclick="openFinalCodeModal()" class="w-full bg-rose-600 hover:bg-rose-500 text-white rounded-full py-4 px-8 font-black text-xl shadow-[0_10px_30px_rgba(225,29,72,0.5)] border-2 border-rose-400 flex items-center justify-center gap-3 transition transform hover:scale-105 animate-pulse">
                <i class="fa-solid fa-lock"></i> 輸入終極密碼停止計時
            </button>
        </div>
        
        <div id="test-scan-btn" class="fixed bottom-2 right-2 z-20">
            <button onclick="simulateScan()" class="bg-slate-700 text-xs px-2 py-1 rounded opacity-50 hover:opacity-100">模擬掃描 (測試)</button>
        </div>
    </div>

    <!-- ==================== 模態框：相機掃描器 ==================== -->
    <div id="modal-scanner" class="modal-overlay">
        <div class="bg-slate-900 border border-slate-700 rounded-2xl p-4 w-11/12 max-w-md relative flex flex-col items-center">
            <button onclick="closeModal('modal-scanner')" class="absolute top-4 right-4 text-slate-400 hover:text-white text-xl z-50">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <h3 class="font-bold text-lg mb-4 text-sky-400">對準站點 QR Code</h3>
            <div id="reader"></div>
            <p class="text-xs text-rose-400 font-bold mt-4 text-center" id="scan-warning"></p>
            <p class="text-xs text-slate-500 mt-2 text-center">必須掃描總部指派的指定地點。<br>如果無法開啟相機，請按右下角「模擬掃描」。</p>
        </div>
    </div>

    <!-- ==================== 模態框：隨機題庫挑戰 ==================== -->
    <div id="modal-quiz" class="modal-overlay">
        <div class="bg-slate-900 border border-sky-900 rounded-2xl p-6 w-11/12 max-w-md relative shadow-[0_0_30px_rgba(14,165,233,0.2)]">
            <div class="text-center mb-6">
                <div class="inline-block bg-sky-900/50 rounded-full p-4 mb-3 border border-sky-500/50">
                    <i id="quiz-icon" class="fa-solid text-4xl text-sky-400"></i>
                </div>
                <h3 id="quiz-station-name" class="font-black text-2xl text-white">站點名稱</h3>
                <span id="quiz-type" class="text-xs bg-slate-800 text-sky-300 px-3 py-1 rounded-full border border-slate-700 font-mono mt-2 inline-block">領域</span>
            </div>
            
            <div class="bg-slate-800 p-4 rounded-xl border-l-4 border-sky-500 mb-6">
                <p id="quiz-question" class="text-lg leading-relaxed text-white">題目內容將在這裡顯示...</p>
            </div>
            
            <div id="quiz-options" class="flex flex-col gap-3">
                <!-- 選項按鈕由 JS 動態生成 -->
            </div>
            
            <div id="quiz-feedback" class="hidden"></div>
        </div>
    </div>

    <!-- ==================== 模態框：終極密碼輸入 ==================== -->
    <div id="modal-final-code" class="modal-overlay">
        <div class="bg-slate-900 border border-rose-500 rounded-2xl p-6 w-11/12 max-w-md relative shadow-[0_0_40px_rgba(225,29,72,0.3)]">
            <button onclick="closeModal('modal-final-code')" class="absolute top-4 right-4 text-slate-400 hover:text-white text-xl z-50">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <div class="text-center mb-4">
                <i class="fa-solid fa-lock text-5xl text-rose-500 mb-4 animate-pulse"></i>
                <h3 class="font-black text-3xl text-white tracking-widest">終極防線</h3>
                <p class="text-rose-400 font-bold mt-1 text-sm bg-rose-950/50 inline-block px-3 py-1 rounded-full border border-rose-800"><i class="fa-regular fa-clock fa-spin"></i> 計時仍在進行中！</p>
            </div>
            <div class="bg-slate-800 p-5 rounded-xl border border-slate-700 mb-6 text-center shadow-inner">
                <p class="text-base font-bold text-sky-400 mb-4 bg-slate-900 p-3 rounded-lg border border-sky-900">密碼提示：<br>國家安全日定為每年幾月幾日？</p>
                <!-- 限定輸入 4 位數 -->
                <input type="number" id="final-code-input" pattern="[0-9]*" class="w-full bg-slate-950 border-2 border-slate-600 rounded-xl py-3 text-center text-white font-mono text-4xl tracking-[0.5em] focus:outline-none focus:border-rose-500 transition" placeholder="----" oninput="if(this.value.length > 4) this.value = this.value.slice(0, 4);">
                
                <p class="text-xs text-rose-500 font-bold mt-4 bg-rose-950/30 p-2 rounded"><i class="fa-solid fa-triangle-exclamation"></i> 警告：只有一次輸入機會，答錯即時淘汰！</p>
            </div>
            <button onclick="checkFinalCode()" class="w-full bg-rose-600 hover:bg-rose-500 text-white font-black text-xl py-4 rounded-xl shadow-[0_0_15px_rgba(225,29,72,0.4)] transition transform hover:scale-105">
                提交密碼並停止計時
            </button>
        </div>
    </div>

    <!-- ==================== 視圖 3A：任務成功 (過關) ==================== -->
    <div id="view-success" class="view-section min-h-screen justify-center items-center p-6 text-center">
        <i class="fa-solid fa-shield-check text-8xl text-emerald-500 mb-6 drop-shadow-[0_0_20px_rgba(16,185,129,0.5)]"></i>
        <h1 class="text-4xl font-black text-white mb-2 tracking-widest">任務完成！</h1>
        <p class="text-xl text-emerald-400 font-bold mb-8">終極密碼正確，系統已成功修復</p>
        
        <div class="bg-slate-900 border border-slate-700 rounded-2xl p-6 w-full max-w-sm mb-8">
            <div class="text-sm text-slate-400 mb-1">特工姓名 / 隊伍班別</div>
            <div id="final-team" class="text-2xl font-bold text-white mb-4">---</div>
            <div class="text-sm text-slate-400 mb-1">最終鎖定用時</div>
            <div id="final-timer" class="font-mono text-4xl font-black text-sky-400 drop-shadow-md">00:00:00</div>
        </div>
        
        <p class="text-lg font-bold text-slate-400 border border-slate-600 bg-slate-800 px-6 py-3 rounded-full inline-block">
            請向指揮中心工作人員展示此畫面。
        </p>
    </div>

    <!-- ==================== 視圖 3B：任務失敗 (淘汰) ==================== -->
    <div id="view-eliminated" class="view-section min-h-screen justify-center items-center p-6 text-center">
        <i class="fa-solid fa-skull-crossbones text-8xl text-rose-600 mb-6 drop-shadow-[0_0_20px_rgba(225,29,72,0.5)] animate-pulse"></i>
        <h1 class="text-4xl font-black text-white mb-2 tracking-widest">任務失敗</h1>
        <p class="text-xl text-rose-500 font-bold mb-8">密碼輸入錯誤，特攻隊伍已被淘汰！</p>
        
        <div class="bg-slate-900 border border-rose-900 rounded-2xl p-6 w-full max-w-sm mb-8 relative overflow-hidden">
            <div class="absolute inset-0 bg-rose-600 opacity-10"></div>
            <div class="text-sm text-slate-400 mb-1 relative z-10">特工姓名 / 隊伍班別</div>
            <div id="eliminated-team" class="text-2xl font-bold text-white mb-4 relative z-10">---</div>
            <div class="text-sm text-slate-400 mb-1 relative z-10">淘汰終止時間</div>
            <div id="eliminated-timer" class="font-mono text-3xl font-black text-rose-500 relative z-10">00:00:00</div>
        </div>
        
        <p class="text-lg font-bold text-slate-400 border border-slate-600 bg-slate-800 px-6 py-3 rounded-full inline-block">
            請返回操場指揮中心報到。
        </p>
    </div>

    <script>
        // --- 1. 物理站點列表 (20 個) ---
        const STATIONS_DATA = [
            { id: "STATION_01", location: "操場台階" },
            { id: "STATION_02", location: "操場體育室" },
            { id: "STATION_03", location: "操場籃球架" },
            { id: "STATION_04", location: "操場看台下方" },
            { id: "STATION_05", location: "操場旗杆" },
            { id: "STATION_06", location: "小食部飲水機後" },
            { id: "STATION_07", location: "小食部垃圾桶旁" },
            { id: "STATION_08", location: "小食部左側牆" },
            { id: "STATION_09", location: "小食部收銀台旁" },
            { id: "STATION_10", location: "健身室外" },
            { id: "STATION_11", location: "禮堂側門" },
            { id: "STATION_12", location: "禮堂舞台側" },
            { id: "STATION_13", location: "禮堂正門門框" },
            { id: "STATION_14", location: "禮堂入口公告板" },
            { id: "STATION_15", location: "實驗桌 1" },
            { id: "STATION_16", location: "門口右側" },
            { id: "STATION_17", location: "視藝室" },
            { id: "STATION_18", location: "音樂室" },
            { id: "STATION_19", location: "圖書館正門" },
            { id: "STATION_20", location: "電腦室外" }
        ];

        // --- 2. 隨機國安題庫 (20 題) ---
        const QUESTIONS_BANK = [
            { id: "Q01", icon: "fa-money-bill-transfer", type: "金融安全", question: "遇到聲稱保證有「200%高回報」的投資 App，你應該怎麼做？", options: ["立即下載並投入資金", "核實來源，警惕金融詐騙", "借錢給同學一起投資"], answer: 1 },
            { id: "Q02", icon: "fa-network-wired", type: "網絡安全", question: "在公眾地方，哪種連接 Wi-Fi 的習慣最容易危害個人數據安全？", options: ["連接沒有密碼的免費不明 Wi-Fi", "使用需輸入密碼的官方 Wi-Fi", "使用自己的手機數據網絡"], answer: 0 },
            { id: "Q03", icon: "fa-plane-arrival", type: "社會安全", question: "有遊客誤信網上假新聞，以為香港街頭不安全，你作為旅遊大使應如何應對？", options: ["不予理會", "承認香港很危險", "有禮貌地澄清，並介紹香港治安良好的實況"], answer: 2 },
            { id: "Q04", icon: "fa-chart-line", type: "經濟安全", question: "大量偽鈔流入市面，對國家經濟安全最大的危害是什麼？", options: ["市民錢包變重", "破壞貨幣信用，導致市場混亂", "銀行會有更多工作"], answer: 1 },
            { id: "Q05", icon: "fa-fingerprint", type: "數據安全", question: "AI Deepfake (深偽技術) 常被用來偽造名人影片，我們應該具備什麼態度？", options: ["眼見為實，全部相信", "隨意轉發給親友", "保持懷疑，多方核實資訊來源"], answer: 2 },
            { id: "Q06", icon: "fa-building-columns", type: "金融安全", question: "政府推動「數碼港元」等中央銀行數碼貨幣的主要目的是什麼？", options: ["取代所有信用卡", "提升支付安全性及防範非法資金流動", "方便黑客入侵"], answer: 1 },
            { id: "Q07", icon: "fa-globe", type: "網絡安全", question: "收到附有奇怪連結 (非.gov.hk) 的政府短訊，應該？", options: ["直接點擊連結填寫資料", "致電官方防騙熱線 18222 查詢", "轉發到所有群組"], answer: 1 },
            { id: "Q08", icon: "fa-users", type: "社會安全", question: "維護國家安全只是警察和政府的責任嗎？", options: ["是，與普通市民無關", "不是，每一位市民都有義務", "只與成年人有關"], answer: 1 },
            { id: "Q09", icon: "fa-shield", type: "社會安全", question: "良好的社會治安對發展哪項產業最為重要？", options: ["網絡遊戲業", "旅遊與款待業", "太空科技業"], answer: 1 },
            { id: "Q10", icon: "fa-laptop-code", type: "網絡安全", question: "設定密碼時，以下哪種方式最安全？", options: ["12345678", "自己的生日日期", "包含大小寫字母、數字及特殊符號"], answer: 2 },
            { id: "Q11", icon: "fa-link", type: "經濟安全", question: "香港作為國際金融中心，其地位穩固對國家的意義是？", options: ["沒有任何意義", "是國家經濟發展和對外開放的重要支撐", "只對香港本地有益"], answer: 1 },
            { id: "Q12", icon: "fa-comment-slash", type: "網絡安全", question: "在社交媒體看到來源不明的「學校停課」消息，應該？", options: ["立即轉發", "先向老師或校方網站求證", "留言謾罵"], answer: 1 },
            { id: "Q13", icon: "fa-coins", type: "經濟安全", question: "維護香港聯繫匯率制度穩定，屬於哪一種國家安全領域？", options: ["經濟安全", "資源安全", "科技安全"], answer: 0 },
            { id: "Q14", icon: "fa-user-secret", type: "數據安全", question: "下載手電筒 App 時，如果它要求獲取你的「通訊錄」權限，應該？", options: ["立即同意", "拒絕並解除安裝，保護數據私隱", "只給相簿權限"], answer: 1 },
            { id: "Q15", icon: "fa-train-subway", type: "社會安全", question: "乘搭港鐵時發現有人故意破壞入閘機，這會影響？", options: ["網絡安全", "社會安全與公共秩序", "生態安全"], answer: 1 },
            { id: "Q16", icon: "fa-server", type: "網絡安全", question: "以下哪項是防範電腦勒索軟件 (Ransomware) 的最佳方法？", options: ["定期備份重要資料到離線硬碟", "把密碼寫在螢幕旁邊", "關閉所有防毒軟件"], answer: 0 },
            { id: "Q17", icon: "fa-money-bill-wave", type: "金融安全", question: "洗黑錢活動會嚴重破壞香港聲譽，我們應如何防範？", options: ["借出自己的銀行戶口給陌生人賺外快", "妥善保管個人戶口，不借給他人", "多開幾個戶口收錢"], answer: 1 },
            { id: "Q18", icon: "fa-book-bookmark", type: "政治安全", question: "《香港國安法》主要防範、制止和懲治哪類行為？", options: ["亂拋垃圾", "分裂國家、顛覆國家政權等嚴重行為", "交通違例"], answer: 1 },
            { id: "Q19", icon: "fa-unlock-keyhole", type: "網絡安全", question: "為了防範「撞庫」攻擊（黑客嘗試登入不同網站），我們應該？", options: ["所有帳號使用同一組簡單密碼", "不同平台使用不同的強密碼", "不要設定密碼"], answer: 1 },
            { id: "Q20", icon: "fa-ship", type: "經濟安全", question: "香港作為自由港，打擊走私活動對維護哪方面的安全最重要？", options: ["經濟安全與社會安全", "文化安全", "太空安全"], answer: 0 }
        ];

        // --- 3. 系統狀態變數 ---
        let state = {
            teamName: "",
            startTime: null,
            timerInterval: null,
            targetCount: 10,
            completedCount: 0,
            visitedStations: new Set(),
            usedQuestions: new Set(),
            passportHistory: [],
            nextTargetStation: null,
            currentQuizData: null,
            html5QrcodeScanner: null
        };

        function switchView(viewId) {
            document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
            document.getElementById(viewId).classList.add('active');
        }

        // --- 隨機指派下一站 ---
        function assignNextTarget() {
            if (state.completedCount >= state.targetCount) {
                state.nextTargetStation = null;
                document.getElementById('next-location-name').innerText = "操場指揮中心";
                document.getElementById('next-location-name').classList.add('text-emerald-400');
                document.getElementById('target-directive').classList.replace('border-sky-500/50', 'border-emerald-500/50');
                document.querySelector('#target-directive i.fa-radar').className = "fa-solid fa-flag-checkered text-emerald-400";
                return;
            }

            const unvisited = STATIONS_DATA.filter(s => !state.visitedStations.has(s.id));
            const randomStation = unvisited[Math.floor(Math.random() * unvisited.length)];
            state.nextTargetStation = randomStation;
            document.getElementById('next-location-name').innerText = randomStation.location;
        }

        function startMission() {
            const input = document.getElementById('team-input').value.trim();
            if (!input) {
                alert("特攻探員，請先輸入您的隊伍班別！");
                return;
            }
            
            state.teamName = input.toUpperCase();
            document.getElementById('display-team').innerText = state.teamName;
            
            state.startTime = new Date();
            state.timerInterval = setInterval(updateTimer, 1000); // 開始計時
            
            assignNextTarget();
            renderPassport();
            switchView('view-dashboard');
        }

        function updateTimer() {
            const now = new Date();
            const diff = new Date(now - state.startTime);
            const hh = String(diff.getUTCHours()).padStart(2, '0');
            const mm = String(diff.getUTCMinutes()).padStart(2, '0');
            const ss = String(diff.getUTCSeconds()).padStart(2, '0');
            document.getElementById('display-timer').innerText = `${hh}:${mm}:${ss}`;
        }

        // --- 渲染護照與控制底部按鈕 ---
        function renderPassport() {
            const grid = document.getElementById('badges-grid');
            grid.innerHTML = '';
            
            for (let i = 0; i < state.targetCount; i++) {
                const historyData = state.passportHistory[i];
                const isUnlocked = !!historyData;
                
                let contentHtml = '';
                if (isUnlocked) {
                    contentHtml = `
                        <img src="${historyData.qrUrl}" alt="QR" class="absolute inset-0 w-full h-full object-cover opacity-80 mix-blend-multiply pointer-events-none p-1 rounded-xl">
                        <div class="absolute inset-0 flex items-center justify-center bg-white/20">
                            <i class="fa-solid fa-circle-check text-4xl text-sky-500 drop-shadow-md"></i>
                        </div>
                        <span class="badge-label">${historyData.location}</span>
                    `;
                } else {
                    contentHtml = `
                        <span class="slot-num">${i + 1}</span>
                        <span class="badge-label text-slate-600">未解碼</span>
                    `;
                }

                grid.innerHTML += `<div class="badge-slot ${isUnlocked ? 'unlocked' : ''}">${contentHtml}</div>`;
            }

            document.getElementById('badge-count').innerText = state.completedCount;
            document.getElementById('progress-bar').style.width = `${(state.completedCount / state.targetCount) * 100}%`;

            // 當集齊 10 個，不停止計時，切換底部按鈕為「輸入終極密碼」
            if (state.completedCount >= state.targetCount) {
                document.getElementById('action-scan').classList.add('hidden');
                document.getElementById('test-scan-btn').classList.add('hidden');
                document.getElementById('action-final').classList.remove('hidden');
            }
        }

        function openScanner() {
            document.getElementById('scan-warning').innerText = "";
            document.getElementById('modal-scanner').classList.add('active');
            
            if(!state.html5QrcodeScanner) state.html5QrcodeScanner = new Html5Qrcode("reader");
            const config = { fps: 10, qrbox: { width: 250, height: 250 } };
            
            state.html5QrcodeScanner.start(
                { facingMode: "environment" }, config,
                (decodedText) => { handleScanResult(decodedText); },
                (errorMessage) => { }
            ).catch(err => {
                alert("無法啟動相機，請使用「模擬掃描」按鈕。");
                closeModal('modal-scanner');
            });
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
            // 清空密碼輸入框
            if(modalId === 'modal-final-code') document.getElementById('final-code-input').value = "";
            
            if(modalId === 'modal-scanner' && state.html5QrcodeScanner) {
                state.html5QrcodeScanner.stop().catch(err => console.log("Stop failed", err));
            }
        }

        function simulateScan() {
            if (state.nextTargetStation) {
                handleScanResult(state.nextTargetStation.id);
            }
        }

        function handleScanResult(scannedData) {
            const station = STATIONS_DATA.find(s => s.id === scannedData);
            if (station) {
                if (station.id !== state.nextTargetStation.id) {
                    if (state.visitedStations.has(station.id)) {
                        document.getElementById('scan-warning').innerHTML = `<i class="fa-solid fa-triangle-exclamation"></i> 錯誤：此站點的印章已獲取！請前往：${state.nextTargetStation.location}`;
                    } else {
                        document.getElementById('scan-warning').innerHTML = `<i class="fa-solid fa-ban"></i> 錯誤：這不是總部指派的路線！請立即前往：${state.nextTargetStation.location}`;
                    }
                    return;
                }
                closeModal('modal-scanner');
                openQuiz(station);
            }
        }

        function openQuiz(station) {
            const availableQuestions = QUESTIONS_BANK.filter(q => !state.usedQuestions.has(q.id));
            const randomQuestion = availableQuestions[Math.floor(Math.random() * availableQuestions.length)];
            
            state.currentQuizData = { station: station, question: randomQuestion };
            
            document.getElementById('quiz-icon').className = `fa-solid ${randomQuestion.icon} text-4xl text-sky-400`;
            document.getElementById('quiz-station-name').innerText = `地點：${station.location}`;
            document.getElementById('quiz-type').innerText = randomQuestion.type;
            document.getElementById('quiz-question').innerText = randomQuestion.question;
            
            const optionsContainer = document.getElementById('quiz-options');
            optionsContainer.innerHTML = '';
            
            randomQuestion.options.forEach((opt, index) => {
                const btn = document.createElement('button');
                btn.className = "w-full bg-slate-800 hover:bg-slate-700 border border-slate-600 text-left px-5 py-4 rounded-xl transition text-white text-md shadow-md";
                btn.innerHTML = `<span class="font-bold text-sky-400 mr-2">${String.fromCharCode(65 + index)}.</span> ${opt}`;
                btn.onclick = () => checkAnswer(index, btn);
                optionsContainer.appendChild(btn);
            });

            document.getElementById('quiz-feedback').className = "hidden";
            document.getElementById('modal-quiz').classList.add('active');
        }

        function checkAnswer(selectedIndex, btnElement) {
            const quizData = state.currentQuizData;
            const optionsContainer = document.getElementById('quiz-options');
            const feedback = document.getElementById('quiz-feedback');
            
            Array.from(optionsContainer.children).forEach(btn => btn.disabled = true);

            if (selectedIndex === quizData.question.answer) {
                btnElement.classList.replace('bg-slate-800', 'bg-emerald-600');
                btnElement.classList.replace('border-slate-600', 'border-emerald-500');
                
                state.visitedStations.add(quizData.station.id);
                state.usedQuestions.add(quizData.question.id);
                
                const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${quizData.station.id}&color=0284c7&bgcolor=ffffff&margin=5`;
                state.passportHistory.push({
                    stationId: quizData.station.id,
                    location: quizData.station.location,
                    qrUrl: qrUrl
                });
                
                state.completedCount++;
                assignNextTarget();
                
                if (state.completedCount < state.targetCount) {
                    feedback.innerHTML = `
                        <div class="bg-emerald-900/40 border border-emerald-500 p-4 rounded-xl mt-4 shadow-lg text-left">
                            <div class="text-emerald-400 font-bold text-lg mb-3 flex items-center gap-2"><i class="fa-solid fa-circle-check"></i> 密碼正確！選項卡已匯入。</div>
                            <div class="bg-slate-900 rounded-lg p-3 border border-slate-700 shadow-inner">
                                <span class="text-sky-400 text-xs font-bold tracking-wider uppercase"><i class="fa-solid fa-route"></i> 總部新指令：前往下一站</span><br>
                                <span class="text-white font-black text-xl tracking-wide mt-1 block animate-pulse">${state.nextTargetStation.location}</span>
                            </div>
                        </div>
                    `;
                } else {
                    feedback.innerHTML = `
                        <div class="bg-emerald-900/50 border border-emerald-500 p-4 rounded-xl mt-4 shadow-lg">
                            <div class="text-emerald-400 font-bold text-lg mb-2"><i class="fa-solid fa-circle-check"></i> 密碼正確！10個徽章已集齊。</div>
                            <div class="text-rose-400 font-black text-xl animate-pulse mt-2"><i class="fa-solid fa-lock"></i> 請點擊下方按鈕，輸入終極密碼方可停止計時！</div>
                        </div>
                    `;
                }
                
                feedback.className = "block mt-2";
                
                setTimeout(() => {
                    closeModal('modal-quiz');
                    renderPassport(); 
                }, 4000);
                
            } else {
                btnElement.classList.replace('bg-slate-800', 'bg-rose-600');
                btnElement.classList.replace('border-slate-600', 'border-rose-500');
                optionsContainer.children[quizData.question.answer].classList.replace('bg-slate-800', 'bg-emerald-900');
                optionsContainer.children[quizData.question.answer].classList.replace('border-slate-600', 'border-emerald-500');
                
                feedback.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i> 答案錯誤！系統防護已重置。<br>請關閉視窗，重新掃描以獲取【新問題】。';
                feedback.className = "text-center mt-4 font-bold text-sm text-rose-400 block border border-rose-500/50 bg-rose-900/30 p-3 rounded-lg";
            }
        }

        // --- 終極密碼防線邏輯 ---
        function openFinalCodeModal() {
            document.getElementById('modal-final-code').classList.add('active');
        }

        function checkFinalCode() {
            const inputField = document.getElementById('final-code-input');
            const code = inputField.value.trim();
            
            if (code.length !== 4) {
                alert("請輸入完整的 4 位數字密碼！");
                return;
            }

            // 無論對錯，一旦提交立刻停止計時！
            clearInterval(state.timerInterval);
            const finalTimeStr = document.getElementById('display-timer').innerText;
            
            closeModal('modal-final-code');

            if (code === "0415") { // 國家安全日 4月15日
                document.getElementById('final-team').innerText = state.teamName;
                document.getElementById('final-timer').innerText = finalTimeStr;
                switchView('view-success');
            } else {
                // 答錯淘汰
                document.getElementById('eliminated-team').innerText = state.teamName;
                document.getElementById('eliminated-timer').innerText = finalTimeStr;
                switchView('view-eliminated');
            }
        }

    </script>
</body>
</html>
